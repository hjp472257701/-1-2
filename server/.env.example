# 复制本文件为 server/.env 后填写（勿提交 .env）
# cp server/.env.example server/.env

PORT=3001

# SQLite 路径；生产环境建议绝对路径，例如 /var/lib/thesis-data/data.sqlite3
DB_PATH=./data.sqlite3

# 导出 CSV、/admin 管理页使用；请改为长随机串（openssl rand -hex 32）
EXPORT_TOKEN=

# 可选：前端与 API 不同域时，填前端来源，多个用英文逗号分隔
# CORS_ORIGIN=https://你的前端域名

# 可选：与前端公网地址一致（不要末尾 /），用于管理端生成完整邀请链接
# PUBLIC_WEB_URL=https://你的公网IP或域名
